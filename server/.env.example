# LLM Provider (OpenRouter by default — provider-agnostic via OpenAI-compatible API)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=put_key_here
LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

