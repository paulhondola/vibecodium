# Primary LLM provider — DeepSeek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_KEY=your-deepseek-key-here
LLM_MODEL=deepseek-chat

# Local LM Studio (re-enable when ready)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_KEY=lm-studio
# LLM_MODEL=qwen2.5-coder-32b-instruct
LOCAL_MODEL=qwen2.5-coder-32b-instruct

# GitHub Integration (for creating repositories)
GITHUB_TOKEN_REPO=your-github-personal-access-token-here
